    if raw == nil {
        return nil, nil
    }
    defer C.thetadatadx_streaming_event_free(raw)

    event := &StreamEvent{
        Kind: StreamEventKind(raw.kind),
    }

    // contractFromC converts a C ThetaDataDxContract into the Go-idiomatic *Contract.
    // Returns nil only when symbol is NULL, which indicates the SDK has not
    // yet resolved the contract_id to a ContractAssigned frame.
    contractFromC := func(c C.ThetaDataDxContract) *Contract {
        if c.symbol == nil {
            return nil
        }
        out := &Contract{
            Symbol:  C.GoString(c.symbol),
            SecType: int32(c.sec_type),
        }
        if bool(c.has_expiration) {
            v := int32(c.expiration)
            out.Expiration = &v
        }
        if bool(c.has_is_call) {
            v := bool(c.is_call)
            out.IsCall = &v
        }
        if bool(c.has_strike) {
            v := int32(c.strike)
            out.Strike = &v
        }
        return out
    }

    switch event.Kind {
    case StreamQuoteEvent:
        q := raw.quote
        event.Quote = &StreamQuote{
            ContractID:   int32(q.contract_id),
            Contract:     contractFromC(q.contract),
            MsOfDay:      int32(q.ms_of_day),
            BidSize:      int32(q.bid_size),
            BidExchange:  int32(q.bid_exchange),
            Bid:          float64(q.bid),
            BidCondition: int32(q.bid_condition),
            AskSize:      int32(q.ask_size),
            AskExchange:  int32(q.ask_exchange),
            Ask:          float64(q.ask),
            AskCondition: int32(q.ask_condition),
            Date:         int32(q.date),
            ReceivedAtNs: uint64(q.received_at_ns),
        }
    case StreamTradeEvent:
        t := raw.trade
        event.Trade = &StreamTrade{
            ContractID:     int32(t.contract_id),
            Contract:       contractFromC(t.contract),
            MsOfDay:        int32(t.ms_of_day),
            Sequence:       int32(t.sequence),
            ExtCondition1:  int32(t.ext_condition1),
            ExtCondition2:  int32(t.ext_condition2),
            ExtCondition3:  int32(t.ext_condition3),
            ExtCondition4:  int32(t.ext_condition4),
            Condition:      int32(t.condition),
            Size:           int32(t.size),
            Exchange:       int32(t.exchange),
            Price:          float64(t.price),
            ConditionFlags: int32(t.condition_flags),
            PriceFlags:     int32(t.price_flags),
            VolumeType:     int32(t.volume_type),
            RecordsBack:    int32(t.records_back),
            Date:           int32(t.date),
            ReceivedAtNs:   uint64(t.received_at_ns),
        }
    case StreamOpenInterestEvent:
        oi := raw.open_interest
        event.OpenInterest = &StreamOpenInterest{
            ContractID:   int32(oi.contract_id),
            Contract:     contractFromC(oi.contract),
            MsOfDay:      int32(oi.ms_of_day),
            OpenInterest: int32(oi.open_interest),
            Date:         int32(oi.date),
            ReceivedAtNs: uint64(oi.received_at_ns),
        }
    case StreamOhlcvcEvent:
        o := raw.ohlcvc
        event.Ohlcvc = &StreamOhlcvc{
            ContractID:   int32(o.contract_id),
            Contract:     contractFromC(o.contract),
            MsOfDay:      int32(o.ms_of_day),
            Open:         float64(o.open),
            High:         float64(o.high),
            Low:          float64(o.low),
            Close:        float64(o.close),
            Volume:       int64(o.volume),
            Count:        int64(o.count),
            Date:         int32(o.date),
            ReceivedAtNs: uint64(o.received_at_ns),
        }
    case StreamControlEvent:
        ctrl := raw.control
        detail := ""
        if ctrl.detail != nil {
            detail = C.GoString(ctrl.detail)
        }
        event.Control = &StreamControl{
            Kind:   int32(ctrl.kind),
            ID:     int32(ctrl.id),
            Detail: detail,
        }
    case StreamRawDataEvent:
        rd := raw.raw_data
        event.RawData = &StreamRawData{
            Code: uint8(rd.code),
        }
        if rd.payload != nil && rd.payload_len > 0 {
            event.RawData.Payload = C.GoBytes(unsafe.Pointer(rd.payload), C.int(rd.payload_len))
        }
    }

    return event, nil
}
