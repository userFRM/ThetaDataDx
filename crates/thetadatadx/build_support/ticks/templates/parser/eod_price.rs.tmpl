    // EOD price field: decode to f64 from Price or Number cell.
    fn eod_price(row: &crate::proto::DataValueList, idx: usize) -> Result<f64, DecodeError> {
        let Some(dv) = row.values.get(idx) else {
            return Err(DecodeError::MissingCell { column: idx });
        };
        match dv.data_type.as_ref() {
            Some(crate::proto::data_value::DataType::Price(p)) => Ok(tdbe::types::price::Price::new(p.value, p.r#type).to_f64()),
            Some(crate::proto::data_value::DataType::Number(n)) => Ok(*n as f64),
            Some(crate::proto::data_value::DataType::NullValue(_)) => Ok(0.0),
            None => Err(DecodeError::TypeMismatch {
                column: idx,
                expected: "Price|Number",
                observed: "Unset",
            }),
            other => Err(DecodeError::TypeMismatch {
                column: idx,
                expected: "Price|Number",
                observed: crate::decode::observed_name(other),
            }),
        }
    }

