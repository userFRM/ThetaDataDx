    // EOD numeric field widened to i64 (for volume/count) — same cell types as eod_num, i64 target.
    fn eod_num64(row: &crate::proto::DataValueList, idx: usize) -> Result<i64, DecodeError> {
        let Some(dv) = row.values.get(idx) else {
            return Err(DecodeError::MissingCell { column: idx });
        };
        match dv.data_type.as_ref() {
            Some(crate::proto::data_value::DataType::Number(n)) => Ok(*n),
            Some(crate::proto::data_value::DataType::Price(p)) => Ok(i64::from(p.value)),
            Some(crate::proto::data_value::DataType::Timestamp(ts)) => Ok(i64::from(crate::decode::timestamp_to_ms_of_day(ts.epoch_ms))),
            Some(crate::proto::data_value::DataType::NullValue(_)) => Ok(0),
            None => Err(DecodeError::TypeMismatch {
                column: idx,
                expected: "Number|Price|Timestamp",
                observed: "Unset",
            }),
            other => Err(DecodeError::TypeMismatch {
                column: idx,
                expected: "Number|Price|Timestamp",
                observed: crate::decode::observed_name(other),
            }),
        }
    }

