    // EOD date fields may arrive as Price, Number, or Timestamp cells.
    // Numeric arms (Number and Price.value) carry a packed YYYYMMDD that
    // must round-trip through the canonical Gregorian validator —
    // calendar-impossible payloads like 20260230 raise `InvalidDate`
    // instead of casting straight through as they did pre-round-2.
    // `DataValue.number` is wire-typed `int64`, so the Number arm
    // bounds-checks against `i32` before the Gregorian validator runs;
    // a payload like `4_315_207_525` (== `(1 << 32) + 20_240_229`)
    // raises `InvalidDate` instead of low-32-bit-truncating into a real
    // date. `Price.value` is already typed `i32` on the wire so no
    // width guard is needed there.
    fn eod_date(row: &crate::proto::DataValueList, idx: usize) -> Result<i32, DecodeError> {
        let Some(dv) = row.values.get(idx) else {
            return Err(DecodeError::MissingCell { column: idx });
        };
        match dv.data_type.as_ref() {
            Some(crate::proto::data_value::DataType::Number(n)) => {
                let n32 = match i32::try_from(*n) {
                    Ok(v) => v,
                    Err(_) => return Err(DecodeError::InvalidDate { raw: n.to_string() }),
                };
                if !tdbe::time::is_valid_yyyymmdd(n32) {
                    return Err(DecodeError::InvalidDate { raw: n.to_string() });
                }
                Ok(n32)
            }
            Some(crate::proto::data_value::DataType::Price(p)) => {
                if !tdbe::time::is_valid_yyyymmdd(p.value) {
                    return Err(DecodeError::InvalidDate { raw: p.value.to_string() });
                }
                Ok(p.value)
            }
            Some(crate::proto::data_value::DataType::Timestamp(ts)) => Ok(tdbe::time::timestamp_to_date(ts.epoch_ms)),
            Some(crate::proto::data_value::DataType::NullValue(_)) => Ok(0),
            None => Err(DecodeError::TypeMismatch {
                column: idx,
                expected: "Number|Price|Timestamp",
                observed: "Unset",
            }),
            other => Err(DecodeError::TypeMismatch {
                column: idx,
                expected: "Number|Price|Timestamp",
                observed: crate::decode::observed_name(other),
            }),
        }
    }

