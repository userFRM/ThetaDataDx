                expiration: match _cid_exp_idx {
                    Some(i) => {
                        let dv = row.values.get(i).ok_or(DecodeError::MissingCell { column: i })?;
                        match dv.data_type.as_ref() {
                            Some(crate::proto::data_value::DataType::Number(n)) => {
                                // Round-2 / Round-3 routed the numeric arm
                                // through `is_valid_yyyymmdd`, but
                                // `DataValue.number` is wire-typed `int64`
                                // and the validator ran on `*n as i32` —
                                // payloads like `4_315_207_525`
                                // (== `(1 << 32) + 20_240_229`) silently
                                // truncated to `20_240_229` and slipped past
                                // the calendar check on every wildcard-tick
                                // parser with `contract_id = true`
                                // (`parse_trade_ticks`, `parse_quote_ticks`,
                                // `parse_eod_ticks`, all greeks variants).
                                // Bounds-check via `i32::try_from` first so
                                // out-of-range integers raise `InvalidDate`
                                // with the raw int64 captured for
                                // diagnostics.
                                let n32 = match i32::try_from(*n) {
                                    Ok(v) => v,
                                    Err(_) => return Err(DecodeError::InvalidDate { raw: n.to_string() }),
                                };
                                if !tdbe::time::is_valid_yyyymmdd(n32) {
                                    return Err(DecodeError::InvalidDate { raw: n.to_string() });
                                }
                                n32
                            }
                            Some(crate::proto::data_value::DataType::Text(s)) => parse_iso_date(s)?,
                            Some(crate::proto::data_value::DataType::NullValue(_)) => 0,
                            None => return Err(DecodeError::TypeMismatch {
                                column: i,
                                expected: "Number|Text",
                                observed: "Unset",
                            }),
                            other => return Err(DecodeError::TypeMismatch {
                                column: i,
                                expected: "Number|Text",
                                observed: crate::decode::observed_name(other),
                            }),
                        }
                    }
                    None => 0,
                },
