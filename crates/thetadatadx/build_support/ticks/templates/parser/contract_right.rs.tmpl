                right: match _cid_right_idx {
                    Some(i) => {
                        let dv = row.values.get(i).ok_or(DecodeError::MissingCell { column: i })?;
                        match dv.data_type.as_ref() {
                            Some(crate::proto::data_value::DataType::Number(n)) => *n as i32,
                            Some(crate::proto::data_value::DataType::Text(s)) => match s.as_str() {
                                "CALL" | "C" => 67,
                                "PUT" | "P" => 80,
                                // Sibling-arm cleanup: the hand-written
                                // `parse_option_contracts_v3` right-text arm
                                // already surfaces unknown text as
                                // `UnknownEnumVariant`, but this
                                // generator-emitted arm coalesced silently to
                                // `0` — masking schema drift on every wildcard
                                // tick parser with `contract_id = true`. Mirror
                                // the canonical strict-decode policy so a
                                // future server addition (e.g. binary options)
                                // fails loud at the boundary instead of
                                // corrupting downstream filters.
                                other => return Err(DecodeError::UnknownEnumVariant {
                                    field: "right",
                                    raw: other.to_string(),
                                }),
                            },
                            Some(crate::proto::data_value::DataType::NullValue(_)) => 0,
                            None => return Err(DecodeError::TypeMismatch {
                                column: i,
                                expected: "Number|Text",
                                observed: "Unset",
                            }),
                            other => return Err(DecodeError::TypeMismatch {
                                column: i,
                                expected: "Number|Text",
                                observed: crate::decode::observed_name(other),
                            }),
                        }
                    }
                    None => 0,
                },
