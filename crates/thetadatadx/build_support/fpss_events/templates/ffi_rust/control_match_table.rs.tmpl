            let detail_ptr = cstring.as_ref().map_or(ptr::null(), |cs| cs.as_ptr());
            FfiBufferedEvent {
                event: TdxFpssEvent {
                    kind: TdxFpssEventKind::Control,
                    control: TdxFpssControl {
                        kind,
