    let __NAME__ = match unsafe { cstr_to_str(__NAME__) } {
        Some(value) => value,
        None => {
            set_error("__NAME__ is null or invalid UTF-8");
            return empty;
        }
    };
    args.insert(
        "__NAME__".to_string(),
        thetadatadx::EndpointArgValue::Str(__NAME__.to_string()),
    );
