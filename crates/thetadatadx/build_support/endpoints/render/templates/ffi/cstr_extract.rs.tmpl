    let __NAME__ = match unsafe { cstr_to_str(__NAME__) } {
        Ok(Some(value)) => value,
        Ok(None) => {
            set_error("__NAME__ is null");
            return empty;
        }
        Err(e) => {
            set_error(&format!("__NAME__ is not valid UTF-8: {e}"));
            return empty;
        }
    };
    args.insert(
        "__NAME__".to_string(),
        thetadatadx::EndpointArgValue::Str(__NAME__.to_string()),
    );
