{
  "name": "thetadatadx",
  "version": "8.0.23",
  "description": "Native ThetaData SDK for Node.js — powered by Rust via napi-rs",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/userFRM/ThetaDataDx"
  },
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "thetadatadx",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "aarch64-apple-darwin",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node --test __tests__/basic.test.mjs __tests__/dropped_events.test.mjs",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2"
  },
  "optionalDependencies": {
    "thetadatadx-linux-x64-gnu": "8.0.23",
    "thetadatadx-darwin-arm64": "8.0.23",
    "thetadatadx-win32-x64-msvc": "8.0.23"
  },
  "engines": {
    "node": ">= 20"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ]
}
