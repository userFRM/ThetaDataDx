std::vector<OptionContract> MarketData::option_list_contracts(const std::string& request_type, const std::string& date, const EndpointRequestOptions& options, ColumnPresence* out_columns) const {
    detail::FfiEndpointRequestOptions ffi_options(options);
    thetadatadx_clear_error();
    ThetaDataDxColumnPresence presence_raw{nullptr, 0};
    ThetaDataDxOptionContractArray arr = thetadatadx_option_list_contracts_with_options(market_data_handle(), request_type.c_str(), date.c_str(), &ffi_options.raw, out_columns ? &presence_raw : nullptr);
    if (out_columns != nullptr) { *out_columns = ColumnPresence(presence_raw); }
    {
        const std::string err = detail::last_ffi_error_raw();
        if (!err.empty()) {
            const int32_t code = thetadatadx_last_error_code();
            thetadatadx_option_contract_array_free(arr);
            detail::throw_for_code(code, err);
        }
    }
    std::vector<OptionContract> result;
    result.reserve(arr.len);
    for (size_t i = 0; i < arr.len; ++i) {
        OptionContract c;
        c.symbol = arr.data[i].symbol ? std::string(arr.data[i].symbol) : "";
        c.expiration = arr.data[i].expiration;
        c.strike = arr.data[i].strike;
        c.right = static_cast<char>(arr.data[i].right);
        result.push_back(std::move(c));
    }
    thetadatadx_option_contract_array_free(arr);
    return result;
}

